{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "eqeqeq": ["error", "always"],
    "curly": ["warn", "multi-line"],
    "no-var": "error",
    "prefer-const": "warn"
  },
  "overrides": [
    {
      "files": ["app/**/webapp/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      },
      "globals": {
        "sap": "readonly"
      }
    },
    {
      "files": ["test/**/*.js"],
      "env": {
        "jest": true
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "gen/",
    "dist/",
    "app/**/webapp/resources/",
    "app/**/webapp/test/changes_*"
  ]
}