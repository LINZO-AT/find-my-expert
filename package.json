{
  "name": "findmyexpert",
  "version": "1.0.0",
  "description": "Find My Expert — SAP Austria Internal Expert Directory",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sap/cds": "^9.1.0",
    "@sap/xsenv": "^5.0.0",
    "@sap/xssec": "^4.0.0",
    "@cap-js/postgres": "^1.0.0",
    "express": "^4.18.0",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.1.0",
    "@cap-js/sqlite": "^1.0.0",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "kill-port": "lsof -ti :4004 | xargs kill -9 2>/dev/null; true",
    "prewatch": "npm run kill-port",
    "watch": "cds watch",
    "build": "cds build --production",
    "test": "jest --testPathPattern=test/",
    "watch-experts": "cds watch --open experts/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-admin": "cds watch --open admin/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        },
        "db": {
          "kind": "postgres"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/experts",
    "app/admin"
  ]
}
