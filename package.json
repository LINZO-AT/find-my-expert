{
  "name": "findmyexpert",
  "version": "1.0.0",
  "description": "Find My Expert — SAP Austria Internal Expert Directory",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@cap-js/hana": "^2.0.0",
    "@sap/audit-logging": "^7.0.0",
    "@sap/cds": "^9.1.0",
    "@sap/cds-common-content": "^3.1.0",
    "@sap/xsenv": "^5.0.0",
    "@sap/xssec": "^4.0.0",
    "express": "^4.18.0",
    "passport": "0.7.0"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2.0.0",
    "@sap/cds-dk": "^9.1.0",
    "@sap/eslint-plugin-cds": "^3.0.0",
    "archiver": "^7.0.1",
    "cds-plugin-ui5": "^0.13.0",
    "eslint": "^8.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "cds-serve",
    "kill-port": "lsof -ti :4004 | xargs kill -9 2>/dev/null; true",
    "prewatch": "npm run kill-port && cds deploy --to sqlite",
    "watch": "cds watch",
    "watch-flp": "cds watch --open findmyexpert-search/webapp/test/flpSandbox.html#Shell-home --livereload false",
    "build": "cds build --production",
    "test": "jest --testPathPattern=test/",
    "watch-search": "cds watch --open findmyexpert-search/webapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-manage-experts": "cds watch --open findmyexpert-manage-experts/webapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-manage-roles": "cds watch --open findmyexpert-manage-roles/webapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-manage-topics": "cds watch --open findmyexpert-manage-topics/webapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "lint": "eslint srv/ app/ --ext .js",
    "lint:fix": "eslint srv/ app/ --ext .js --fix"
  },
  "cds": {
    "build": {
      "tasks": [
        {
          "for": "hana",
          "src": "db"
        },
        {
          "for": "nodejs",
          "src": "srv"
        }
      ]
    },
    "requires": {
      "audit-log": {
        "kind": "audit-log-to-console",
        "[production]": {
          "kind": "audit-log-service"
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        },
        "db": {
          "kind": "hana"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/findmyexpert-search",
    "app/findmyexpert-manage-experts",
    "app/findmyexpert-manage-roles",
    "app/findmyexpert-manage-topics"
  ]
}
