{
  "mcpServers": {
    "io.github.SAP/open-ux-tools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@sap-ux/fiori-mcp-server@0.6.45", "fiori-mcp"],
      "autoApprove": [
        "search_docs",
        "list_fiori_apps",
        "list_functionality",
        "get_functionality_details",
        "execute_functionality"
      ]
    },
    "cds-mcp": {
      "command": "npx",
      "args": ["-y", "@cap-js/mcp-server"],
      "env": {},
      "autoApprove": ["search_model", "search_docs"]
    },
    "ui5-mcp": {
      "command": "npx",
      "args": ["-y", "@ui5/mcp-server"],
      "env": {},
      "autoApprove": [
        "get_guidelines",
        "get_api_reference",
        "get_project_info",
        "create_ui5_app",
        "get_version_info",
        "get_integration_cards_guidelines",
        "create_integration_card",
        "get_typescript_conversion_guidelines",
        "run_ui5_linter",
        "run_manifest_validation"
      ]
    },
    "sap.tools.hyperspace.portal.s4c.mcp/mcp": {
      "type": "streamableHttp",
      "url": "https://mcp.s4c.portal.hyperspace.tools.sap/mcp",
      "autoApprove": [
        "list_product_standards",
        "search_requirement",
        "get_requirement"
      ]
    },
    "ui5-webc-mcp": {
      "command": "npx",
      "args": ["-y", "@ui5/webcomponents-mcp-server"],
      "env": {},
      "autoApprove": [
        "get_component_api",
        "get_doc",
        "get_guidelines",
        "list_docs"
      ]
    },
    "github.com/modelcontextprotocol/servers/tree/main/src/memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "/home/node/Documents/Cline/MCP/memory/memory.jsonl"
      },
      "disabled": false,
      "autoApprove": [
        "create_entities",
        "create_relations",
        "add_observations",
        "delete_entities",
        "delete_observations",
        "delete_relations",
        "read_graph",
        "search_nodes",
        "open_nodes"
      ]
    },
    "github.com/upstash/context7-mcp": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "disabled": false,
      "autoApprove": ["resolve-library-id", "query-docs"]
    },
    "github.com/modelcontextprotocol/servers/tree/main/src/puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "autoApprove": [
        "puppeteer_navigate",
        "puppeteer_screenshot",
        "puppeteer_click",
        "puppeteer_fill",
        "puppeteer_select",
        "puppeteer_hover",
        "puppeteer_evaluate"
      ]
    }
  }
}
