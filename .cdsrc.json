{
  "requires": {
    "db": {
      "kind": "sqlite",
      "database": "db.sqlite"
    },
    "auth": {
      "kind": "mocked",
      "users": {
        "admin": {
          "password": "admin",
          "roles": ["Admin", "authenticated-user"]
        },
        "viewer": {
          "password": "viewer",
          "roles": ["Viewer", "authenticated-user"]
        }
      }
    }
  },
  "server": {
    "port": 4004
  },
  "[production]": {
    "requires": {
      "db": { "kind": "postgres" }
    }
  }
}