{
  "requires": {
    "db": {
      "kind": "sqlite",
      "database": "db.sqlite"
    },
    "auth": {
      "kind": "mocked",
      "users": {
        "anonymous": {
          "roles": ["Admin", "Viewer", "authenticated-user"]
        },
        "*": {
          "roles": ["Admin", "Viewer", "authenticated-user"]
        }
      }
    }
  },
  "server": {
    "port": 4004
  },
  "[production]": {
    "requires": {
      "db":   { "kind": "postgres" },
      "auth": { "kind": "xsuaa" }
    }
  }
}
