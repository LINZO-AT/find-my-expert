{
  "_version": "1.73.1",
  "sap.app": {
    "id": "experts",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "7a487772-a393-4915-932f-d9f984293e9c"
    },
    "dataSources": {
      "mainService": {
        "uri": "/api/catalog/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ListReport.ListReportController": {
            "controllerName": "experts.ext.controller.AdminNavExtension"
          }
        }
      }
    },
    "dependencies": {
      "minUI5Version": "1.136.7",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "experts.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ExpertSearchList",
          "target": "ExpertSearchList"
        },
        {
          "pattern": "ExpertSearch({key}):?query:",
          "name": "ExpertSearchObjectPage",
          "target": "ExpertSearchObjectPage"
        },
        {
          "pattern": "AdminExperts:?query:",
          "name": "AdminExpertsList",
          "target": "AdminExpertsList"
        },
        {
          "pattern": "AdminExperts({key}):?query:",
          "name": "AdminExpertsObjectPage",
          "target": "AdminExpertsObjectPage"
        },
        {
          "pattern": "AdminRoles:?query:",
          "name": "AdminRolesList",
          "target": "AdminRolesList"
        },
        {
          "pattern": "AdminRoles({key}):?query:",
          "name": "AdminRolesObjectPage",
          "target": "AdminRolesObjectPage"
        },
        {
          "pattern": "AdminTopics:?query:",
          "name": "AdminTopicsList",
          "target": "AdminTopicsList"
        },
        {
          "pattern": "AdminTopics({key}):?query:",
          "name": "AdminTopicsObjectPage",
          "target": "AdminTopicsObjectPage"
        },
        {
          "pattern": "AdminTopics({key})/solutions({key2}):?query:",
          "name": "AdminTopicsSolutionObjectPage",
          "target": "AdminTopicsSolutionObjectPage"
        }
      ],
      "targets": {
        "ExpertSearchList": {
          "type": "Component",
          "id": "ExpertSearchList",
          "name": "sap.fe.templates.ListReport",
          "viewLevel": 0,
          "options": {
            "settings": {
              "contextPath": "/ExpertSearch",
              "initialLoad": "Enabled",
              "variantManagement": "Page",
              "navigation": {
                "ExpertSearch": {
                  "detail": {
                    "route": "ExpertSearchObjectPage"
                  }
                }
              },
              "content": {
                "header": {
                  "actions": {
                    "adminExperts": {
                      "press": ".extension.experts.ext.controller.AdminNavExtension.onAdminExperts",
                      "visible": true,
                      "enabled": true,
                      "text": "{i18n>AdminExperts}"
                    },
                    "adminRoles": {
                      "press": ".extension.experts.ext.controller.AdminNavExtension.onAdminRoles",
                      "visible": true,
                      "enabled": true,
                      "text": "{i18n>AdminRolesMenu}"
                    },
                    "adminTopics": {
                      "press": ".extension.experts.ext.controller.AdminNavExtension.onAdminTopics",
                      "visible": true,
                      "enabled": true,
                      "text": "{i18n>AdminTopics}"
                    }
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "ExpertSearchObjectPage": {
          "type": "Component",
          "id": "ExpertSearchObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "viewLevel": 1,
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ExpertSearch"
            }
          }
        },
        "AdminExpertsList": {
          "type": "Component",
          "id": "AdminExpertsList",
          "name": "sap.fe.templates.ListReport",
          "viewLevel": 1,
          "options": {
            "settings": {
              "contextPath": "/AdminExperts",
              "initialLoad": "Enabled",
              "variantManagement": "Page",
              "navigation": {
                "AdminExperts": {
                  "detail": {
                    "route": "AdminExpertsObjectPage"
                  }
                }
              }
            }
          }
        },
        "AdminExpertsObjectPage": {
          "type": "Component",
          "id": "AdminExpertsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "viewLevel": 2,
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/AdminExperts"
            }
          }
        },
        "AdminRolesList": {
          "type": "Component",
          "id": "AdminRolesList",
          "name": "sap.fe.templates.ListReport",
          "viewLevel": 1,
          "options": {
            "settings": {
              "contextPath": "/AdminRoles",
              "initialLoad": "Enabled",
              "variantManagement": "Page",
              "navigation": {
                "AdminRoles": {
                  "detail": {
                    "route": "AdminRolesObjectPage"
                  }
                }
              }
            }
          }
        },
        "AdminRolesObjectPage": {
          "type": "Component",
          "id": "AdminRolesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "viewLevel": 2,
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/AdminRoles"
            }
          }
        },
        "AdminTopicsList": {
          "type": "Component",
          "id": "AdminTopicsList",
          "name": "sap.fe.templates.ListReport",
          "viewLevel": 1,
          "options": {
            "settings": {
              "contextPath": "/AdminTopics",
              "initialLoad": "Enabled",
              "variantManagement": "Page",
              "navigation": {
                "AdminTopics": {
                  "detail": {
                    "route": "AdminTopicsObjectPage"
                  }
                }
              }
            }
          }
        },
        "AdminTopicsObjectPage": {
          "type": "Component",
          "id": "AdminTopicsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "viewLevel": 2,
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/AdminTopics",
              "navigation": {
                "solutions": {
                  "detail": {
                    "route": "AdminTopicsSolutionObjectPage"
                  }
                }
              }
            }
          }
        },
        "AdminTopicsSolutionObjectPage": {
          "type": "Component",
          "id": "AdminTopicsSolutionObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "viewLevel": 3,
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/AdminTopics/solutions"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}