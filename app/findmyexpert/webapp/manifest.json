{
  "_version": "2.0.0",
  "sap.app": {
    "id": "com.sap.austria.findmyexpert",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": { "version": "1.0.0" },
    "crossNavigation": {
      "inbounds": {
        "findmyexpert-display": {
          "semanticObject": "findmyexpert",
          "action": "display",
          "title": "{{appTitle}}",
          "icon": "sap-icon://employee",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    },
    "dataSources": {
      "CatalogService": {
        "uri": "/api/catalog/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      },
      "AdminService": {
        "uri": "/api/admin/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.fiori": {
    "registrationIds": ["F-FME-001"],
    "archeType": "transactional"
  },
  "sap.ui5": {
    "flexEnabled": false,
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "minUI5Version": "1.132.1",
    "theme": "sap_horizon",
    "dependencies": {
      "minUI5Version": "1.132.1",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.f": {},
        "sap.uxap": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {}
      }
    },
    "models": {
      "": {
        "dataSource": "CatalogService",
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "admin": {
        "dataSource": "AdminService",
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.sap.austria.findmyexpert.i18n.i18n",
          "supportedLocales": ["de", "en", ""],
          "fallbackLocale": "de"
        }
      }
    },
    "rootView": {
      "viewName": "com.sap.austria.findmyexpert.view.App",
      "type": "XML",
      "id": "app"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "async": true,
        "viewType": "XML",
        "viewPath": "com.sap.austria.findmyexpert.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "bypassed": {
          "target": "Search"
        }
      },
      "routes": [
        { "name": "search",         "pattern": "",                         "target": "Search" },
        { "name": "expertList",     "pattern": "experts",                  "target": "ExpertList" },
        { "name": "expertDetail",   "pattern": "experts/{expertId}",       "target": "ExpertDetail" },
        { "name": "adminExpert",    "pattern": "admin/experts/{expertId}", "target": "AdminExpert" },
        { "name": "adminNew",       "pattern": "admin/experts/new",        "target": "AdminExpert" },
        { "name": "adminSolutions", "pattern": "admin/solutions",          "target": "AdminSolutions" }
      ],
      "targets": {
        "Search":         { "viewName": "Search",         "viewLevel": 0 },
        "ExpertList":     { "viewName": "ExpertList",     "viewLevel": 1 },
        "ExpertDetail":   { "viewName": "ExpertDetail",   "viewLevel": 2 },
        "AdminExpert":    { "viewName": "AdminExpert",    "viewLevel": 2 },
        "AdminSolutions": { "viewName": "AdminSolutions", "viewLevel": 1 }
      }
    }
  }
}
