{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.sap.austria.findmyexpert",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "CatalogService": {
        "uri": "/odata/v4/catalog/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      },
      "AdminService": {
        "uri": "/odata/v4/admin/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
  },
  "sap.fiori": {
    "registrationIds": ["F-FME-001"],
    "archeType": "transactional"
  },
  "sap.ui5": {
    "minUI5Version": "1.132.1",
    "theme": "sap_horizon",
    "dependencies": {
      "minUI5Version": "1.132.1",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.f": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {}
      }
    },
    "models": {
      "": {
        "dataSource": "CatalogService",
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "admin": {
        "dataSource": "AdminService",
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "com.sap.austria.findmyexpert.i18n.i18n" }
      }
    },
    "rootView": {
      "viewName": "com.sap.austria.findmyexpert.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.sap.austria.findmyexpert.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true,
        "bypassed": {
          "target": "Search"
        }
      },
      "routes": [
        { "name": "search",         "pattern": "",                         "target": "Search" },
        { "name": "expertList",     "pattern": "experts",                  "target": "ExpertList" },
        { "name": "expertDetail",   "pattern": "experts/{expertId}",       "target": "ExpertDetail" },
        { "name": "adminExpert",    "pattern": "admin/experts/{expertId}", "target": "AdminExpert" },
        { "name": "adminNew",       "pattern": "admin/experts/new",        "target": "AdminExpert" },
        { "name": "adminSolutions", "pattern": "admin/solutions",          "target": "AdminSolutions" }
      ],
      "targets": {
        "Search":         { "id": "Search",         "viewName": "Search" },
        "ExpertList":     { "id": "ExpertList",     "viewName": "ExpertList" },
        "ExpertDetail":   { "id": "ExpertDetail",   "viewName": "ExpertDetail" },
        "AdminExpert":    { "id": "AdminExpert",    "viewName": "AdminExpert" },
        "AdminSolutions": { "id": "AdminSolutions", "viewName": "AdminSolutions" }
      }
    }
  }
}
