<mvc:View
  controllerName="com.sap.austria.findmyexpert.controller.ExpertList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core">

  <f:DynamicPage id="expertListPage" fitContent="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>expertListTitle}" level="H2" wrapping="true" />
        </f:heading>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            type="Transparent"
            press=".onNavToSearch"
            tooltip="{i18n>searchButton}" />
        </f:navigationActions>
        <f:actions>
          <Button
            text="{i18n>adminExpertTitleNew}"
            type="Emphasized"
            icon="sap-icon://add"
            press=".onAddExpert"
            visible="{userModel>/isAdmin}" />
        </f:actions>
        <f:snappedContent>
          <HBox wrap="Wrap" alignItems="Center">
            <Select id="topicFilterSnapped"
              width="auto"
              items="{ path: '/Topics', parameters: { $orderby: 'name' } }"
              change=".onFilterChange">
              <core:Item key="" text="{i18n>expertListAllTopics}" />
              <items><core:Item key="{ID}" text="{name}" /></items>
            </Select>
            <Select id="locationFilterSnapped" width="auto" change=".onFilterChange" class="sapUiTinyMarginBegin">
              <core:Item key="" text="{i18n>expertListAllLocations}" />
              <core:Item key="AT" text="{i18n>loc_AT}" />
              <core:Item key="DE" text="{i18n>loc_DE}" />
              <core:Item key="CH" text="{i18n>loc_CH}" />
            </Select>
            <SearchField id="nameSearchSnapped" width="200px" search=".onFilterChange" class="sapUiTinyMarginBegin" />
          </HBox>
        </f:snappedContent>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <HBox wrap="Wrap" alignItems="Center" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
          <Select
            id="topicFilter"
            width="auto"
            ariaLabelledBy="topicFilterLabel"
            items="{ path: '/Topics', parameters: { $orderby: 'name' } }"
            change=".onFilterChange">
            <core:Item key="" text="{i18n>expertListAllTopics}" />
            <items><core:Item key="{ID}" text="{name}" /></items>
          </Select>
          <Select id="locationFilter" width="auto" ariaLabelledBy="locationFilterLabel" change=".onFilterChange" class="sapUiTinyMarginBegin">
            <core:Item key="" text="{i18n>expertListAllLocations}" />
            <core:Item key="AT" text="{i18n>loc_AT}" />
            <core:Item key="DE" text="{i18n>loc_DE}" />
            <core:Item key="CH" text="{i18n>loc_CH}" />
          </Select>
          <SearchField id="nameSearch" width="200px" search=".onFilterChange" class="sapUiTinyMarginBegin" ariaLabelledBy="nameSearchLabel" />
          <Button
            text="{i18n>expertListResetFilter}"
            press=".onResetFilters"
            type="Transparent"
            class="sapUiTinyMarginBegin" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <Table
        id="expertTable"
        growing="true"
        growingThreshold="25"
        sticky="ColumnHeaders"
        ariaLabelledBy="expertTableTitle"
        items="{
          path: '/Experts',
          parameters: {
            $expand: 'roles($expand=solution($expand=topic))',
            $orderby: 'lastName,firstName'
          }
        }">
        <columns>
          <Column><Text text="{i18n>expertListColName}" /></Column>
          <Column minScreenWidth="Tablet" demandPopin="true" width="6rem">
            <Text text="{i18n>expertListColLocation}" />
          </Column>
          <Column minScreenWidth="Tablet" demandPopin="true">
            <Text text="{i18n>expertListColSolutions}" />
          </Column>
          <Column visible="{userModel>/isAdmin}" hAlign="End" width="6rem">
            <Text text="{i18n>expertListColActions}" />
          </Column>
        </columns>
        <items>
          <ColumnListItem press=".onExpertPress" type="Navigation">
            <cells>
              <ObjectIdentifier
                title="{= ${firstName} + ' ' + ${lastName}}"
                text="{email}" />
              <ObjectStatus text="{location}" />
              <Text id="solutionCountText" text="{
                path: 'roles',
                targetType: 'any',
                formatter: '.formatRoleCount'
              }" />
              <HBox visible="{userModel>/isAdmin}" justifyContent="End">
                <Button
                  icon="sap-icon://edit"
                  tooltip="{i18n>expertListEditBtn}"
                  press=".onEditExpert"
                  type="Transparent" />
                <Button
                  icon="sap-icon://delete"
                  tooltip="{i18n>expertListDeleteBtn}"
                  press=".onDeleteExpert"
                  type="Transparent" />
              </HBox>
            </cells>
          </ColumnListItem>
        </items>
        <noData>
          <IllustratedMessage
            illustrationType="sapIllus-SearchEarth"
            title="{i18n>searchEmptyTitle}"
            description="{i18n>searchEmptyDescription}" />
        </noData>
      </Table>
    </f:content>

  </f:DynamicPage>
</mvc:View>
