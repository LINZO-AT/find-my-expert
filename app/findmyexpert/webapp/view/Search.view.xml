<mvc:View
  controllerName="com.sap.austria.findmyexpert.controller.Search"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core">

  <f:DynamicPage id="searchPage" fitContent="false" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>appTitle}" level="H2" wrapping="true" />
        </f:heading>
        <f:actions>
          <Button
            text="{i18n>expertListTitle}"
            type="Transparent"
            icon="sap-icon://list"
            press=".onNavToExpertList" />
          <Button
            text="{i18n>adminSolutionsTitle}"
            type="Transparent"
            icon="sap-icon://settings"
            press=".onNavToAdminSolutions"
            visible="{userModel>/isAdmin}" />
          <Button
            text="{i18n>loginButton}"
            type="Transparent"
            icon="sap-icon://person-placeholder"
            press=".onLogin"
            visible="{= !${userModel>/userName} || ${userModel>/userName} === 'anonymous' }" />
          <Button
            text="{= ${userModel>/userName} }"
            type="Transparent"
            icon="sap-icon://account"
            press=".onLogout"
            visible="{= !!${userModel>/userName} &amp;&amp; ${userModel>/userName} !== 'anonymous' }" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="false">
        <HBox alignItems="Center" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom" width="100%">
          <SearchField
            id="searchField"
            placeholder="{i18n>searchPlaceholder}"
            width="560px"
            search=".onSearch"
            ariaLabelledBy="searchFieldLabel" />
          <Button
            text="{i18n>searchButton}"
            type="Emphasized"
            press=".onSearch"
            class="sapUiSmallMarginBegin" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <VBox class="sapUiMediumMarginBeginEnd" alignItems="Center">

        <MessageStrip
          id="mockModeBanner"
          text="{i18n>searchMockMode}"
          type="Information"
          showIcon="true"
          visible="false"
          class="sapUiSmallMarginBottom" />

        <BusyIndicator
          id="searchBusy"
          visible="false"
          class="sapUiMediumMarginTop"
          size="2rem" />

        <IllustratedMessage
          id="emptyState"
          illustrationType="sapIllus-SearchEarth"
          title="{i18n>searchEmptyTitle}"
          description="{i18n>searchEmptyDescription}"
          visible="true" />

        <Title
          id="resultsTitle"
          level="H4"
          visible="false"
          class="sapUiSmallMarginBottom" />

        <FlexBox
          id="resultsContainer"
          wrap="Wrap"
          visible="false"
          class="sapUiTinyMarginTop"
          width="100%">
          <customData>
            <core:CustomData key="sap-ui-fastnavgroup" value="true" writeToDom="true" />
          </customData>
        </FlexBox>

      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>