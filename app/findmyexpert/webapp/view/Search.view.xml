<mvc:View
  controllerName="com.sap.austria.findmyexpert.controller.Search"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core">

  <!--
    No page title: FLP Shell already shows "Find My Expert".
    showHeader="false" avoids redundant chrome.
  -->
  <Page id="searchPage" showHeader="false">
    <content>
      <VBox
        class="sapUiMediumMarginBeginEnd"
        alignItems="Center">

        <!-- Search bar row -->
        <HBox
          class="sapUiMediumMarginTop sapUiSmallMarginBottom"
          alignItems="Center"
          justifyContent="Start"
          width="100%">
          <SearchField
            id="searchField"
            placeholder="{i18n>searchPlaceholder}"
            width="560px"
            search=".onSearch"
            ariaLabelledBy="searchFieldLabel" />
          <Button
            text="{i18n>searchButton}"
            type="Emphasized"
            press=".onSearch"
            class="sapUiSmallMarginBegin" />
          <ToolbarSpacer />
          <Button
            text="{i18n>expertListTitle}"
            type="Transparent"
            icon="sap-icon://list"
            press=".onNavToExpertList"
            class="sapUiSmallMarginBegin" />
        </HBox>

        <MessageStrip
          id="mockModeBanner"
          text="{i18n>searchMockMode}"
          type="Information"
          showIcon="true"
          visible="false"
          class="sapUiSmallMarginBottom"
          width="100%" />

        <BusyIndicator
          id="searchBusy"
          visible="false"
          class="sapUiMediumMarginTop"
          size="2rem" />

        <IllustratedMessage
          id="emptyState"
          illustrationType="sapIllus-SearchEarth"
          title="{i18n>searchEmptyTitle}"
          description="{i18n>searchEmptyDescription}"
          visible="true" />

        <Title
          id="resultsTitle"
          level="H4"
          visible="false"
          class="sapUiSmallMarginBottom" />

        <FlexBox
          id="resultsContainer"
          wrap="Wrap"
          visible="false"
          class="sapUiTinyMarginTop"
          width="100%">
          <customData>
            <core:CustomData key="sap-ui-fastnavgroup" value="true" writeToDom="true" />
          </customData>
        </FlexBox>

      </VBox>
    </content>
  </Page>
</mvc:View>
