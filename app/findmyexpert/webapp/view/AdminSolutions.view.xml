<mvc:View
  controllerName="com.sap.austria.findmyexpert.controller.AdminSolutions"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core">

  <f:DynamicPage id="adminSolutionsPage" fitContent="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <VBox xmlns="sap.m">
            <Title text="{i18n>adminSolutionsTitle}" level="H2" wrapping="true" />
            <Label text="{i18n>adminSolutionsSubtitle}" wrapping="true" class="sapUiTinyMarginTop sapUiSmallMarginBottom" />
          </VBox>
        </f:heading>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            type="Transparent"
            press=".onNavBack"
            tooltip="{i18n>backBtn}" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <HBox alignItems="Stretch" justifyContent="Start" width="100%" class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd">

        <!-- Topics column -->
        <VBox width="50%">
          <OverflowToolbar style="Clear">
            <Title text="{i18n>adminSolutionsTopics}" level="H4" />
            <ToolbarSpacer />
            <Button
              icon="sap-icon://add"
              tooltip="{i18n>adminSolutionsAddTopic}"
              press=".onAddTopic"
              type="Transparent" />
          </OverflowToolbar>
          <List
            id="topicList"
            items="{admin>/Topics}"
            selectionChange=".onTopicSelect"
            mode="SingleSelectMaster"
            backgroundDesign="Solid"
            class="sapUiTinyMarginTop">
            <CustomListItem type="Active" class="sapUiTinyMarginBottom">
              <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%" class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom">
                <VBox class="sapUiSmallMarginEnd" width="100%">
                  <Text text="{admin>name}" class="sapMTitle sapMTitleStyleH5" />
                  <Text text="{admin>description}" class="sapUiTinyMarginTop sapMLabel" wrapping="true" />
                </VBox>
                <HBox>
                  <Button icon="sap-icon://edit" press=".onEditTopic" type="Transparent" tooltip="{i18n>adminSolutionsEditTopic}" />
                  <Button icon="sap-icon://delete" press=".onDeleteTopic" type="Transparent" tooltip="{i18n>adminSolutionsDeleteTopic}" />
                </HBox>
              </HBox>
            </CustomListItem>
            <noData>
              <IllustratedMessage
                illustrationType="sapIllus-EmptyList"
                title="{i18n>adminSolutionsTopics}"
                description="{i18n>adminSolutionsNoTopics}" />
            </noData>
          </List>
        </VBox>

        <!-- Vertical Divider -->
        <VBox width="1px" class="sapUiSmallMarginBeginEnd sapUiResponsiveContentPadding">
          <ToolbarSeparator />
        </VBox>

        <!-- Solutions column -->
        <VBox width="50%">
          <OverflowToolbar style="Clear">
            <Title text="{i18n>adminSolutionsSolutions}" level="H4" />
            <ToolbarSpacer />
            <Button
              id="addSolutionBtn"
              icon="sap-icon://add"
              tooltip="{i18n>adminSolutionsAddSolution}"
              press=".onAddSolution"
              type="Transparent"
              enabled="{viewModel>/topicSelected}" />
          </OverflowToolbar>
          <List
            id="solutionList"
            items="{viewModel>/solutions}"
            backgroundDesign="Solid"
            class="sapUiTinyMarginTop">
            <CustomListItem class="sapUiTinyMarginBottom">
              <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%" class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom">
                <VBox class="sapUiSmallMarginEnd" width="100%">
                  <Text text="{viewModel>name}" class="sapMTitle sapMTitleStyleH5" />
                  <Text text="{viewModel>description}" class="sapUiTinyMarginTop sapMLabel" wrapping="true" />
                </VBox>
                <HBox>
                  <Button icon="sap-icon://edit" press=".onEditSolution" type="Transparent" tooltip="{i18n>adminSolutionsEditSolution}" />
                  <Button icon="sap-icon://delete" press=".onDeleteSolution" type="Transparent" tooltip="{i18n>adminSolutionsDeleteSolution}" />
                </HBox>
              </HBox>
            </CustomListItem>
            <noData>
              <IllustratedMessage
                illustrationType="sapIllus-EmptyList"
                title="{i18n>adminSolutionsSolutions}"
                description="{i18n>adminSolutionsSelectTopicFirst}" />
            </noData>
          </List>
        </VBox>

      </HBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>