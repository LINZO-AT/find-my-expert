{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./gen/srv",
    "rootDir": ".",
    "paths": {
      "#cds-models/*": ["./@cds-models/*/index.ts"]
    }
  },
  "include": [
    "srv/**/*.ts",
    "db/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "gen",
    "dist",
    "app"
  ]
}