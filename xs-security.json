{
  "xsappname": "find-my-expert",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Viewer",
      "description": "Viewer Access"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Admin Access"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "Viewer Role",
      "scope-references": ["$XSAPPNAME.Viewer"]
    },
    {
      "name": "Admin",
      "description": "Admin Role",
      "scope-references": ["$XSAPPNAME.Admin"]
    }
  ],
  "role-collections": [
    {
      "name": "FindMyExpert_Viewer",
      "description": "Viewer Role Collection for Find My Expert",
      "role-template-references": ["$XSAPPNAME.Viewer"]
    },
    {
      "name": "FindMyExpert_Admin",
      "description": "Admin Role Collection for Find My Expert",
      "role-template-references": ["$XSAPPNAME.Admin"]
    }
  ]
}